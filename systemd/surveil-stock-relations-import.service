[Unit]
Description=Surveil stock relation config import
After=surveil-db-init.service

[Service]
Type=oneshot
User=surveil
WorkingDirectory=/opt/surveil
EnvironmentFile=-/opt/surveil/.env
ExecStart=/opt/surveil/.venv/bin/python /opt/surveil/scripts/stock_relations.py --config /opt/surveil/config/stock_relations.json
StandardOutput=append:/opt/surveil/logs/stock-relations-import.log
StandardError=append:/opt/surveil/logs/stock-relations-import.err.log
